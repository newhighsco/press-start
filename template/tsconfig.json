{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@newhighsco/ts-config/next",
  "compilerOptions": {
    "paths": {
      "~components/*": ["./src/components/*"],
      "~config": ["./site.config"],
      "~data/*": ["./src/data/*"],
      "~images/*": ["./src/images/*"],
      "~styles/*": ["./src/styles/_*", "./src/styles/*"],
      "~theme": ["./src/theme"],
      "~types": ["./src/types"]
    }
  },
  "include": ["**/*"]
}
